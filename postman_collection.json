{
	"info": {
		"name": "Expense Tracker API",
		"description": "API untuk Personal Expense Tracker dengan autentikasi JWT",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://192.168.123.4:8080"
		},
		{
			"key": "token",
			"value": ""
		}
	],
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.status) {",
									"    pm.collectionVariables.set(\"token\", jsonData.data.token);",
									"}"
								]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"admin\",\n  \"password\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/login",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "login"]
						}
					}
				},
				{
					"name": "Register",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"userbaru\",\n  \"password\": \"123456\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/auth/register",
							"host": ["{{base_url}}"],
							"path": ["api", "auth", "register"]
						}
					}
				}
			]
		},
		{
			"name": "Dashboard",
			"item": [
				{
					"name": "Get Dashboard",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/dashboard",
							"host": ["{{base_url}}"],
							"path": ["api", "dashboard"]
						}
					}
				}
			]
		},
		{
			"name": "Categories",
			"item": [
				{
					"name": "List Categories",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/categories",
							"host": ["{{base_url}}"],
							"path": ["api", "categories"]
						}
					}
				},
				{
					"name": "Create Category",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nama_kategori\": \"Makanan\",\n  \"icon\": \"fastfood\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/categories",
							"host": ["{{base_url}}"],
							"path": ["api", "categories"]
						}
					}
				},
				{
					"name": "Get Category by ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/categories/1",
							"host": ["{{base_url}}"],
							"path": ["api", "categories", "1"]
						}
					}
				},
				{
					"name": "Update Category",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nama_kategori\": \"Makanan & Minuman\",\n  \"icon\": \"restaurant\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/categories/1",
							"host": ["{{base_url}}"],
							"path": ["api", "categories", "1"]
						}
					}
				},
				{
					"name": "Delete Category",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/categories/1",
							"host": ["{{base_url}}"],
							"path": ["api", "categories", "1"]
						}
					}
				}
			]
		},
		{
			"name": "Transactions",
			"item": [
				{
					"name": "List Transactions",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/transactions",
							"host": ["{{base_url}}"],
							"path": ["api", "transactions"]
						}
					}
				},
				{
					"name": "Create Transaction",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"kategori_id\": 1,\n  \"nominal\": 25000,\n  \"keterangan\": \"Makan siang\",\n  \"tanggal_transaksi\": \"2026-06-10\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/transactions",
							"host": ["{{base_url}}"],
							"path": ["api", "transactions"]
						}
					}
				},
				{
					"name": "Get Transaction by ID",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/transactions/1",
							"host": ["{{base_url}}"],
							"path": ["api", "transactions", "1"]
						}
					}
				},
				{
					"name": "Update Transaction",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"kategori_id\": 1,\n  \"nominal\": 30000,\n  \"keterangan\": \"Makan siang + minum\",\n  \"tanggal_transaksi\": \"2026-06-10\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/transactions/1",
							"host": ["{{base_url}}"],
							"path": ["api", "transactions", "1"]
						}
					}
				},
				{
					"name": "Delete Transaction",
					"request": {
						"method": "DELETE",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/transactions/1",
							"host": ["{{base_url}}"],
							"path": ["api", "transactions", "1"]
						}
					}
				}
			]
		},
		{
			"name": "Reports",
			"item": [
				{
					"name": "Daily Report",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/report/daily?date=2026-06-10",
							"host": ["{{base_url}}"],
							"path": ["api", "report", "daily"],
							"query": [
								{
									"key": "date",
									"value": "2026-06-10"
								}
							]
						}
					}
				},
				{
					"name": "Monthly Report",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/report/monthly?month=6&year=2026",
							"host": ["{{base_url}}"],
							"path": ["api", "report", "monthly"],
							"query": [
								{
									"key": "month",
									"value": "6"
								},
								{
									"key": "year",
									"value": "2026"
								}
							]
						}
					}
				},
				{
					"name": "Stats Report",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/report/stats?start_date=2026-01-01&end_date=2026-12-31",
							"host": ["{{base_url}}"],
							"path": ["api", "report", "stats"],
							"query": [
								{
									"key": "start_date",
									"value": "2026-01-01"
								},
								{
									"key": "end_date",
									"value": "2026-12-31"
								}
							]
						}
					}
				}
			]
		}
	]
}
