<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".network.AppController"
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.ExpenseTracker"
        android:usesCleartextTraffic="true"
        tools:targetApi="34"
        android:icon="@mipmap/logo"
        android:roundIcon="@mipmap/logo">
        <activity
            android:name=".ui.activity.LoginActivity"
            android:exported="true"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.activity.RegisterActivity"
            android:label="Daftar Akun"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />
        <activity
            android:name=".ui.activity.MainActivity"
            android:exported="false"
            android:screenOrientation="portrait" />
        <activity android:name=".ui.activity.TransactionsActivity"
            android:label="Transaksi"
            android:screenOrientation="portrait" />
        <activity android:name=".ui.activity.TransactionFormActivity"
            android:label="Tambah Transaksi"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".ui.activity.CategoriesActivity"
            android:label="Kategori"
            android:screenOrientation="portrait" />
        <activity android:name=".ui.activity.CategoryFormActivity"
            android:label="Tambah Kategori"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />
        <activity android:name=".ui.activity.ReportsActivity"
            android:label="Laporan"
            android:screenOrientation="portrait" />
        <activity android:name=".ui.activity.BudgetActivity"
            android:label="Anggaran Bulanan"
            android:screenOrientation="portrait" />
        <activity android:name=".ui.activity.ChartActivity"
            android:label="Grafik"
            android:screenOrientation="portrait" />
        <activity android:name=".ui.activity.ProfileActivity"
            android:label="Profil"
            android:screenOrientation="portrait" />
    </application>

</manifest>
